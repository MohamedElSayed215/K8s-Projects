apiVersion: apps/v1
kind: DaemonSet
metadata:
  name: nginx-ds
spec:
  selector:
    matchLabels:
      app: nginx
      node: worker
  template:
    metadata:
      labels:
        app: nginx
        node: worker
    spec:
      nodeSelector:
        node: worker
      containers:
      - name: nginx
        image: nginx
        env:
        - name: NODE_NAME
          valueFrom:
            fieldRef:
              fieldPath: spec.nodeName
        command: ["/bin/sh", "-c"]
        args:
        - |
          echo "<h1>Node: $NODE_NAME</h1>" > /usr/share/nginx/html/index.html
          nginx -g 'daemon off;';
        ports:
        - containerPort: 80

---
